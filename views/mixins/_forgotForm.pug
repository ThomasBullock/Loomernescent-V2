mixin forgotForm()
	form.form#forgot(action="/auth/forgot" method="POST")
		h2 I forgot my password
		label(for="email") Email
		input(type="email" name="email" data-testid="auth.forgot-form.email-input")
		input(type="text" name="commandant")
		input.button(type="submit" value="Send a Reset" data-testid="auth.forgot-form.submit-btn")