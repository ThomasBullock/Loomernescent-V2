mixin bandCard(band = {})
  .band
    .band__hero
      .band__actions
        if user
          .band__action.band__action--heart
            form.heart(method="POST", action=`/api/v1/bands/${band.id}/loves`)
              - const heartStrings = user.favourites ? user.favourites.map((obj) => obj.bandId) : [];
              - const heartClass = heartStrings.includes(band.id) ? "heart__button--hearted" : "";
              - const hearted = heartStrings.includes(band.id);
              button.heart__button(
                type="submit",
                name="heart",
                class=heartClass,
                aria-label=`${hearted ? 'Remove' : 'Add'} ${band.name} from favourites`,
                aria-pressed=hearted,
                data-testid="bands.list.heart-btn"
              )
                != h.icon("heart")
        if user && user.admin
          .band__action.band__action--edit
            a(
              href=`/bands/${band.id}/edit`,
              aria-label=`Edit ${band.name}`,
              data-testid="bands.list.edit-link"
            )
              != h.icon("pencil")
      img(
        src=band.imagePath ? imageUrl(band.imagePath, { w: 400, h: 400, fo: "auto" }) : imageUrl("/bands/band.jpg"),
        alt=`A photo of ${band.name}`
      )
      h2.title
        a(href=`/band/${band.slug}`) #{ band.name }
    .band__details
      p= band.description ? band.description.split(" ").slice(0, 25).join(" ") : ""
