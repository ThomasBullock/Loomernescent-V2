mixin albumForm(album = {}, mode = "add")
  //- testid uses interpolation intentionally: mode is always 'add' or 'edit',
  //- never user-derived data. Rendered value is a fixed static string per page.
  - const p = `albums.${mode}-form`;
  - const action = album.id ? "/albums/" + album.id : "/albums";
  form.add-album.card(action=action, method="post", enctype="multipart/form-data")
    label(for="title") Title
    input#title(type="text", name="title", data-testid=`${p}.title-input`, value=album.title)
    label(for="artist") Artist
    input#artist(type="text", name="artist", value=album.artist)
    label(for="comments") Comments
    textarea(name="comments")= album.comments
    //- Cover image upload
    label(for="cover") Cover
    if album.imagePath
      img.album-form__preview(
        src=imageUrl(album.imagePath, { w: 200, h: 200, fo: "auto" }),
        alt=album.title,
        width=200
      )
    input#cover(type="file", name="cover", accept="image/png, image/jpeg, image/webp")
    label(for="producer") Producer
    input(
      type="text",
      name="producer",
      placeholder="list personnel separated by comma",
      value=album.producer
    )
    label(for="mixedBy") Mixed By
    input(
      type="text",
      name="mixedBy",
      placeholder="list personnel separated by comma",
      value=album.mixedBy
    )
    label(for="engineer") Engineers
    input(
      type="text",
      name="engineer",
      placeholder="list personnel separated by comma",
      value=album.engineer
    )
    label(for="tracks") Track Listing (Fallback if not on Spotify)
    input(
      type="text",
      name="tracks",
      placeholder="list tracks separated by comma",
      value=album.tracks
    )
    label(for="releaseDate") Release Date
    input(type="date", name="releaseDate", value=album.releaseDate)
    label(for="label") Label
    input(type="text", name="label", placeholder="label", value=album.label)
    label(for="spotifyUrl") Spotify URL
    input#spotifyUrl(type="text", name="spotifyUrl", value=album.spotifyUrl)
    label(for="bandcampUrl") Bandcamp URL
    input#bandcampUrl(type="text", name="bandcampUrl", value=album.bandcampUrl)
    input.button(type="submit", value="Save -<", data-testid=`${p}.submit-btn`)
