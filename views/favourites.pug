extends layout

include mixins/_bandCard
include mixins/_albumCard
include mixins/_pedalCard
include mixins/_pagination

block content
  .inner
    h2(data-testid="favourites.page.bands-section") Favourite Bands
    .bands(data-testid="favourites.page.bands-container")
      each band in bands
        +bandCard(band)
    //- +pagination(page, pages, count, 'bands')
    h2(data-testid="favourites.page.albums-section") Favourite Albums
    .albums(data-testid="favourites.page.albums-container")
      each album in albums
        +albumCard(album)
    h2(data-testid="favourites.page.pedals-section") Favourite Pedals
    .pedals
      each pedal in pedals
        +pedalCard(pedal)
