extends layout

include icons/_youtube
include icons/_cross
include icons/_pick

block meta
  meta(
    name="description",
    content=`Find albums, videos and history for ${band.name} on Loomernescent`
  )
  meta(
    name="keywords",
    content=`${band.name}, ${albums.map(v => v.title).join(", ")}, ${band.personnel.join(", ")}, ${band.tags.join(", ")}, shoegaze, guitar, dreampop, loomernescent, indie`
  )
  meta(property="og:url", content=`http://loomernescent.com/band/${band.slug}`)

block content
  .single
    .single__hero
      img.single__image(
        src=band.gallery && band.gallery.length ? imageUrl(band.gallery[0].filePath, { w: 1600, h: 900, fo: "auto" }) : band.imagePath ? imageUrl(band.imagePath, { w: 1600, h: 900, fo: "auto" }) : imageUrl("/bands/Band.jpg"),
        alt=`A photo of ${band.name}`
      )
      h2.title.title--single(data-testid="bands.detail.name") #{ band.name }
  .single__details
    - if (band.locationAddress)
      - if (band.locationAddress.length > 15)
        .ribbon__wrapper--long
          .ribbon.ribbon--long!= band.locationAddress
      - else
        .ribbon__wrapper
          .ribbon!= band.locationAddress
    .band-info
      .band-info__photo
        img(
          src=band.imagePath ? imageUrl(band.imagePath, { w: 600, h: 600, fo: "auto" }) : imageUrl("/bands/Band.jpg"),
          alt=`A photo of ${band.name}`
        )
      .band-info__facts
        p.single__detail
          strong Years Active:
          != h.buildDatesString(band.yearsActive)
        p.single__detail
          strong Personnel:
          != band.personnel.join(" | ")
        if band.pastPersonnel.length
          p.single__detail
            strong Past Personnel:
            != band.pastPersonnel.join(" | ")
        p.single__detail
          strong Record Labels:
          != band.labels.join(" | ")
      .band-info__content
        p.single__lead= band.description
  if band.vimeoPl || band.youtubePl
    .single__fullwidth.single__fullwidth--black
      if band.youtubePl
        .single__video
          .single__video-wrapper
            iframe(src=band.youtubePl, frameborder="0", allowfullscreen, title=`YouTube playlist for ${band.name}`)
  if albums.length
    .single__fullwidth.single__fullwidth
      h2.section-heading Albums by #{ band.name }
      .single__albums
        each album in albums
          .single__album
            a(href=`/album/${album.slug}`)
              img(
                src=album.imagePath ? imageUrl(album.imagePath, { w: 400, h: 400, fo: "auto" }) : imageUrl("/bands/band.jpg"),
                alt=`cover artwork for ${album.title} by ${album.artist}`
              )
  if band.gallery && band.gallery.length
    .single__fullwidth.single__fullwidth--ebony
      .single__gallery
        each photo in band.gallery
          .single__gallery-thumb
            button.gallery-thumb-btn.js-gallery-thumb(
              type="button",
              data-large=imageUrl(photo.filePath, { w: 1600 }),
              aria-label=`View photo for ${band.name}`
            )
              img.single__gallery-thumb-img(
                src=imageUrl(photo.filePath, { w: 600, h: 600, fo: "auto" }),
                alt=""
              )
  #galleryModal.modal(role="dialog", aria-modal="true", aria-labelledby="gallery-modal-title")
    .modal__container
      .modal__header
        h3#gallery-modal-title.modal__title #{ band.name }
        button.modal__close(type="button", aria-label="Close gallery")
          +cross
      .modal__body
      .modal__footer
