extends layout

include mixins/_bandCard
include icons/_pick

block meta
  meta(
    name="description",
    content=`Browse shoegaze bands ${tag ? 'tagged with ' + tag : 'by tags'}`
  )
  meta(
    name="keywords",
    content=`${tag ? tag : tags.map(v => v.name).join(", ")}, shoegaze, guitar, fx, pedals, effects, noise, distortion, dreampop, loomer, loomernescent, indie, rock, reverb`
  )
  meta(property="og:url", content="http://loomernescent.com/tags")
  meta(property="og:title", content="Music on the effected side of indie")
  meta(
    property="og:description",
    content="Loomernescent is a curated depository of guitar orientated music thats on the effected side of indie. Discover bands, albums and fx pedals from subgenres such as shoegaze, dreampop and noise rock."
  )
  meta(property="og:image", content="http://loomernescent.com/images/loomernescent_site.jpeg")

block content
  .inner
    h2.title--tags.nexa-rust(data-testid="tags.browse.heading") Bands tagged with #{ tag || 'Tags' }
    ul.tags.tags--list(data-testid="tags.browse.tags-list")
      each t in tags
        li.tag
          a.tag__link(
            href=`/tags/${t.name}`,
            class=t.name === tag ? "tag__link--active" : "",
            aria-current=t.name === tag ? "page" : false,
            data-testid="tags.browse.tag-link"
          )
            +pick(t.name, t.count)
    .bands(data-testid="tags.browse.bands-container")
      each band in bands
        +bandCard(band)
