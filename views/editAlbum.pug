extends layout

include mixins/_albumForm

block content
  .inner
    h2 #{ title }
    - const mode = album && album.id ? "edit" : "add";
    if errors
      ul.errors(data-testid=`albums.${mode}-form.error-message`)
        each err in errors
          li= err
    +albumForm(album, mode)
    if album.id
      form(action=`/albums/${album.id}/delete`, method="post")
        button.btn.btn--delete(type="submit", data-testid="albums.edit-form.delete-btn") Delete Album
