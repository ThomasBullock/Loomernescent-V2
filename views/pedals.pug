extends layout

include mixins/_pedalCard
include mixins/_pagination

block meta
  meta(name="description", content="Browse guitar pedals used by shoegaze bands on Loomernescent")
  meta(
    name="keywords",
    content=`${pedals.map(v => v.brand).join(", ")}, shoegaze, guitar, fx, effects, pedals, loomernescent`
  )
  meta(property="og:url", content="http://loomernescent.com/pedals")

block content
  .inner
    h2.title--albums.nexa-rust= title
    if user && user.admin
      p.admin-actions
        a.button(href="/pedals/new", data-testid="pedals.list.add-link") Add pedal
    .pedals(data-testid="pedals.list.container")
      each pedal in pedals
        +pedalCard(pedal)
    +pagination(page, pages, count, "pedals")
