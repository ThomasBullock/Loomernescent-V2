# --- Database (e.g. Neon) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Tests ---
# Dedicated Neon branch for e2e tests. MUST differ from DATABASE_URL — the test
# harness refuses to run otherwise (safety rail). Create a branch off main in
# the Neon console, then paste its pooled connection string here.
#   TEST_DATABASE_URL=postgresql://neondb_owner:pwd@ep-<branch-id>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
TEST_DATABASE_URL=

# --- HTTP ---
PORT=3000
# Set to "production" in production (enables secure session cookies, etc.)
NODE_ENV=development
# Public site URL (used in emails and links / defaults in MailService)
APP_URL=http://localhost:3000

# --- Session (use a long random string) ---
SESSION_SECRET=change-me

# --- Seed accounts (idempotent upsert via `npm run seed:accounts`) ---
# Creates/updates the baseline dev/admin accounts defined in
# src/seeds/seed-accounts.ts. Safe to run in any environment (upsert by email,
# never destructive). Provide a shared password and/or per-account overrides.
SEED_DEFAULT_PASSWORD=change-me
# SEED_PASSWORD_MOTBOLLOX=
# SEED_PASSWORD_COCHLEAR=
# SEED_PASSWORD_COCHLEARKILL=

# --- Email (Nodemailer + Mailgun SMTP) ---
# Mailgun sandbox: only "authorized recipient" addresses receive mail until you
# add a verified domain. For local dev, point at Mailpit/MailHog (see Project.md).
MAIL_FROM="Loomernescent <noreply@example.com>"
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_LOGIN=postmaster@mg.example.com
MAILGUN_SMTP_PASSWORD=your-mailgun-smtp-password

# --- ImageKit (image hosting + upload) ---
# Dashboard → Developer options → API keys
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
# e.g. https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# --- Optional: Google Static Maps (band map images) ---
# MAP_KEY=
